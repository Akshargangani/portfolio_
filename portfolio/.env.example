# Portfolio Environment Variables

# GitHub
VITE_GITHUB_USERNAME=yourusername

# LeetCode
VITE_LEETCODE_USERNAME=yourusername

# YouTube
VITE_YOUTUBE_CHANNEL_URL=https://www.youtube.com/@yourhandle
VITE_YOUTUBE_CHANNEL_ID=UCyour_channel_id
VITE_YOUTUBE_API_KEY=your_youtube_api_key_here

# Contact form — copy to .env.local and paste your real key from web3forms.com
WEB3FORMS_ACCESS_KEY=YOUR_ACCESS_KEY
VITE_WEB3FORMS_ACCESS_KEY=YOUR_ACCESS_KEY
CONTACT_EMAIL=your.email@gmail.com
VITE_CONTACT_EMAIL=your.email@gmail.com

# Optional: Resend (overrides Web3Forms when set)
# RESEND_API_KEY=re_your_resend_api_key_here
# CONTACT_FROM_EMAIL=Portfolio <onboarding@resend.dev>
